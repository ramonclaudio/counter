{
  "expo": {
    "name": "Counter",
    "slug": "counter",
    "description": "Real-time deal intelligence. Voice AI that fights for your side in any purchase or negotiation.",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "counter",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash-image.png",
      "resizeMode": "contain",
      "backgroundColor": "#000000"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.rmncldyo.counter",
      "appleTeamId": "SWH9LXWCC3",
      "buildNumber": "1",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSMicrophoneUsageDescription": "Counter uses the microphone for voice conversations with your AI deal advisor."
      },
      "associatedDomains": [
        "applinks:terrific-sparrow-894.convex.site"
      ],
      "privacyManifests": {
        "NSPrivacyAccessedAPITypes": [
          {
            "NSPrivacyAccessedAPIType": "NSPrivacyAccessedAPICategoryUserDefaults",
            "NSPrivacyAccessedAPITypeReasons": [
              "CA92.1"
            ]
          }
        ]
      }
    },
    "plugins": [
      [
        "expo-router",
        {
          "asyncRoutes": {
            "default": "development"
          }
        }
      ],
      "expo-splash-screen",
      "expo-secure-store",
      "expo-web-browser",
      "@livekit/react-native-expo-plugin",
      "@config-plugins/react-native-webrtc",
      "./plugins/with-auto-signing"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "updates": {
      "url": "https://u.expo.dev/27495040-f0ab-4f2f-b207-72a0dbc118b6",
      "enableBsdiffPatchSupport": true
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "extra": {
      "router": {
        "asyncRoutes": {
          "default": "development"
        }
      },
      "eas": {
        "projectId": "a273e2b0-3090-4e71-b663-9123433e0423"
      }
    },
    "owner": "ramonclaudio"
  }
}
