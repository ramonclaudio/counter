    "expo-keep-awake": "^55.0.4",
    "expo-linear-gradient": "56.0.0-canary-20260305-5163746",
    "expo-linking": "56.0.0-canary-20260305-5163746",
    "expo-network": "56.0.0-canary-20260305-5163746",
    "expo-router": "56.0.0-canary-20260305-5163746",
    "expo-secure-store": "56.0.0-canary-20260305-5163746",
    "expo-splash-screen": "56.0.0-canary-20260305-5163746",
