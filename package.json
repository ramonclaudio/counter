    "expo-store-review": "^55.0.9",
    "expo-symbols": "56.0.0-canary-20260305-5163746",
    "expo-system-ui": "^55.0.10",
    "expo-updates": "56.0.0-canary-20260305-5163746",
    "expo-web-browser": "56.0.0-canary-20260305-5163746",
    "livekit-client": "^2.17.3",
    "react": "19.2.3",
    "react-native": "^0.84.1",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-keyboard-controller": "1.20.7",
    "react-native-reanimated": "4.2.2",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-svg": "^15.15.4",
    "react-native-worklets": "0.7.4"
  },
  "devDependencies": {
    "@types/react": "~19.2.14",
    "typescript": "~5.9.3"
  },
  "private": true,
  "expo": {
    "install": {
      "exclude": [
        "react-native"
      ]
    }
  },
  "overrides": {
    "@react-navigation/core": "7.15.1",
