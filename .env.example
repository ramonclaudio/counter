# ============================================
# LOCAL DEVELOPMENT (.env.local)
# ============================================
# Copy this file to .env.local and fill in your values.
# Run `bunx convex dev` first to get your deployment URLs.
#
# Optional: Create .env.convex.local as a local backup of your server secrets.
# It won't be read by Convex — just for your reference.

# Convex (auto-populated by `bunx convex dev`)
CONVEX_DEPLOYMENT=dev:your-deployment-slug
EXPO_PUBLIC_CONVEX_URL=https://your-deployment-slug.convex.cloud
EXPO_PUBLIC_CONVEX_SITE_URL=https://your-deployment-slug.convex.site

# App
EXPO_PUBLIC_SITE_URL=counter://
# Must match WEBHOOK_SECRET in Convex dashboard (used to auth /getToken calls)
EXPO_PUBLIC_API_SECRET=<same value as WEBHOOK_SECRET>

# ============================================
# CONVEX DASHBOARD ONLY
# ============================================
# These are SERVER secrets. Do NOT put them in .env.local.
# Set them via CLI: bunx convex env set KEY=value
# Or in dashboard: dashboard.convex.dev → Settings → Environment Variables
#
# SITE_URL=counter://
# SUPPORT_EMAIL=your@email.com
# BETTER_AUTH_SECRET=<run: openssl rand -base64 32>
# WEBHOOK_SECRET=<run: openssl rand -base64 32>
# ELEVENLABS_API_KEY=<from elevenlabs.io>
# ELEVENLABS_AGENT_ID=<your agent ID>
# ELEVENLABS_WEBHOOK_SECRET=<from ElevenLabs webhook config>
# FIRECRAWL_API_KEY=<from firecrawl.dev>
# RESEND_API_KEY=re_xxxxxxxxxxxx
# RESEND_FROM_EMAIL=noreply@yourdomain.com
# RESEND_WEBHOOK_SECRET=whsec_xxxxxxxxxxxx

# ============================================
# EAS BUILD (for cloud builds)
# ============================================
# Set in: expo.dev → Your Project → Environment Variables
#
# EXPO_PUBLIC_CONVEX_URL=<use prod URL for production builds>
# EXPO_PUBLIC_CONVEX_SITE_URL=<use prod URL for production builds>
# EXPO_PUBLIC_SITE_URL=counter://
# EXPO_PUBLIC_API_SECRET=<same value as WEBHOOK_SECRET>
